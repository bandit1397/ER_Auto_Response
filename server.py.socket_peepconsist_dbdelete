from flask import Flask, request, jsonify, render_template
from flask_cors import CORS
from flask_socketio import SocketIO, join_room, emit
import sqlite3
from datetime import datetime, timedelta
import threading
import time

print("🔥 server.py 실행됨")

app = Flask(__name__)
CORS(app)

# =========================
# ⭐ WebSocket 추가
# =========================
socketio = SocketIO(app, cors_allowed_origins="*")

app.url_map.strict_slashes = False

# -------------------------------
# DB 초기화
# -------------------------------
def init_db():
    conn = sqlite3.connect('hospital.db')
    cur = conn.cursor()

    cur.execute("""
    CREATE TABLE IF NOT EXISTS requests (
        requestID TEXT,
        hospital TEXT,
        summary TEXT,
        eta TEXT,
        response TEXT,
        time TEXT,
        UNIQUE(requestID, hospital)
    )
    """)

    conn.commit()
    conn.close()

init_db()

# =======================================================
# 🔥 1시간 자동 삭제 백그라운드 스레드 (추가 기능)
# =======================================================
def cleanup_old_data():
    while True:
        try:
            conn = sqlite3.connect('hospital.db')
            cur = conn.cursor()

            cutoff = (datetime.now() - timedelta(hours=1)).strftime("%Y-%m-%d %H:%M:%S")

            # 1시간 지난 데이터 삭제
            cur.execute("""
            DELETE FROM requests
            WHERE time < ?
            """, (cutoff,))

            conn.commit()
            conn.close()

            print("🧹 1시간 지난 데이터 자동 삭제 실행")

        except Exception as e:
            print("cleanup error:", e)

        time.sleep(300)  # 5분마다 체크


# 스레드 시작
threading.Thread(target=cleanup_old_data, daemon=True).start()

# -------------------------------
# 🟢 WebSocket: 병원 접속 등록
# -------------------------------
@socketio.on('join')
def on_join(data):
    hospital = data['hospital']
    print("🟢 병원 접속:", hospital)

    join_room(hospital)

# -------------------------------
# 🟢 요청 생성 (WebSocket push 추가)
# -------------------------------
@app.route('/request', methods=['POST'])
def create_request():
    data = request.json

    print("🔥 REQUEST 들어옴:", data)

    conn = sqlite3.connect('hospital.db')
    cur = conn.cursor()

    for h in data['hospitals']:
        hospital = h.strip()

        cur.execute("""
        INSERT OR IGNORE INTO requests
        (requestID, hospital, summary, eta, response, time)
        VALUES (?, ?, ?, ?, '', ?)
        """, (
            data['requestID'],
            hospital,
            data.get('summary', ''),
            data.get('eta', ''),
            datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        ))

        socketio.emit("new_request", {
            "requestID": data['requestID'],
            "hospital": hospital,
            "summary": data.get('summary', ''),
            "eta": data.get('eta', '')
        }, room=hospital)

    conn.commit()
    conn.close()

    return jsonify({"status": "ok"})

# -------------------------------
# 🟢 응답 처리
# -------------------------------
@app.route('/response')
def response():
    requestID = request.args.get('requestID')
    hospital = request.args.get('hospital')
    resp = request.args.get('response')

    conn = sqlite3.connect('hospital.db')
    cur = conn.cursor()

    cur.execute("""
    SELECT response FROM requests
    WHERE requestID=? AND hospital=?
    """, (requestID, hospital))

    row = cur.fetchone()

    if row and row[0]:
        conn.close()
        return "already responded"

    cur.execute("""
    UPDATE requests
    SET response=?, time=?
    WHERE requestID=? AND hospital=?
    """, (
        resp,
        datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        requestID,
        hospital
    ))

    conn.commit()
    conn.close()

    socketio.emit("update_status", {
        "requestID": requestID,
        "hospital": hospital,
        "response": resp
    })

    return "ok"

# -------------------------------
# 🟢 상태 조회
# -------------------------------
@app.route('/status/<requestID>')
def status(requestID):
    conn = sqlite3.connect('hospital.db')
    cur = conn.cursor()

    cur.execute("""
    SELECT hospital, summary, eta, response, requestID, time
    FROM requests
    WHERE requestID=?
    ORDER BY hospital, datetime(time) DESC
    """, (requestID,))

    rows = cur.fetchall()
    conn.close()

    latest = {}

    for r in rows:
        hospital = r[0]
        if hospital not in latest:
            latest[hospital] = {
                "hospital": r[0],
                "summary": r[1],
                "eta": r[2],
                "response": r[3],
                "requestID": r[4]
            }

    return jsonify(list(latest.values()))

# -------------------------------
# 🟢 latest (polling)
# -------------------------------
@app.route('/latest/<hospital>')
def latest(hospital):
    conn = sqlite3.connect('hospital.db')
    cur = conn.cursor()

    cur.execute("""
    SELECT requestID, summary, eta, response
    FROM requests
    WHERE hospital=? AND response=''
    ORDER BY time DESC
    LIMIT 1
    """, (hospital,))

    row = cur.fetchone()
    conn.close()

    if not row:
        return jsonify({})

    return jsonify({
        "requestID": row[0],
        "summary": row[1],
        "eta": row[2],
        "response": row[3]
    })

