<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8">
<title>병원</title>

<link rel="manifest" href="/static/manifest.json">

<!-- ✅ 여기 넣기 -->
<style>
body {
  margin: 0;
  background: #020617;
  color: white;
  font-family: 'Segoe UI', Arial;
}

#header {
  background: #111827;
  padding: 15px;
  font-size: 18px;
  text-align: center;
  border-bottom: 2px solid #1f2937;
}

#container {
  text-align: center;
  padding-top: 30px;
}

#card {
  margin: auto;
  width: 320px;
  padding: 20px;
  background: #111827;
  border-radius: 12px;
  box-shadow: 0 0 20px rgba(255,0,0,0.3);
  animation: pulse 1.5s infinite;
}

.hidden {
  display: none;
}

#urgent {
  color: red;
  font-size: 20px;
  margin-bottom: 10px;
}

#reqid {
  font-size: 22px;
  margin-bottom: 15px;
  color: #38bdf8;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 2fr;
  margin-bottom: 15px;
}

.label {
  text-align: left;
  color: #9ca3af;
}

.value {
  text-align: right;
  font-weight: bold;
}

#status {
  margin: 15px 0;
  font-size: 18px;
  color: #22c55e;
}

#buttons button {
  width: 120px;
  padding: 12px;
  margin: 5px;
  font-size: 16px;
  border: none;
  border-radius: 8px;
}

#okBtn {
  background: #16a34a;
}

#noBtn {
  background: #dc2626;
}

#standby {
  margin-top: 50px;
  font-size: 20px;
  color: #facc15;
}

@keyframes pulse {
  0% { box-shadow: 0 0 10px rgba(255,0,0,0.2); }
  50% { box-shadow: 0 0 25px rgba(255,0,0,0.6); }
  100% { box-shadow: 0 0 10px rgba(255,0,0,0.2); }
}
</style>

<script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
</head>

<body onload="init()">

<div id="container">

  <!-- 상단 상태 -->
  <div id="header">
    🏥 HOSPITAL: <span id="hospitalName">{{ hospital }}</span>
  </div>

  <!-- 요청 카드 -->
  <div id="card" class="hidden">

    <div id="urgent">🚨 EMERGENCY</div>

    <div id="reqid">REQ-000</div>

    <div class="grid">
      <div class="label">PATIENT</div>
      <div class="value" id="summary">-</div>

      <div class="label">ETA</div>
      <div class="value" id="eta">-</div>
    </div>

    <div id="status">WAITING</div>

    <div id="buttons">
      <button id="okBtn" onclick="send('가능')" disabled>✔ ACCEPT</button>
      <button id="noBtn" onclick="send('불가')" disabled>✖ REJECT</button>
    </div>

  </div>

  <!-- 대기 화면 -->
  <div id="standby">🟡 STANDBY</div>

</div>

<script>

const SERVER = "http://localhost:5000";
const HOSPITAL = "{{ hospital }}";

// =========================
// 상태
// =========================
let current = null;
let handled = new Set();

let audioCtx = null;
let beepInterval = null;

let confirmed = false;

// =========================
// WebSocket
// =========================
const socket = io(SERVER);

socket.on("connect", () => {
  socket.emit("join", { hospital: HOSPITAL });
});

// =========================
// 초기화
// =========================
function init(){

  if ("Notification" in window) {
    Notification.requestPermission();
  }

  document.body.addEventListener("click", () => {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    ctx.resume();
  }, { once: true });

  // 🚨 서비스워커 등록 (여기에 넣기!)
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/static/sw.js');
  }
}

// =========================
// 버튼
// =========================
function setButtons(state){
  document.getElementById("okBtn").disabled = !state;
  document.getElementById("noBtn").disabled = !state;
}

// =========================
// 알림
// =========================
function notify(reqID, summary){

  if(Notification.permission === "granted"){
    new Notification("🚨 응급 요청", {
      body: `[${reqID}] ${summary}`
    });
  }

  const audio = new Audio("/static/alert.mp3");
  audio.play().catch(()=>{});
}

// =========================
// 사이렌
// =========================
function startBeep(){

  if(audioCtx) return;

  audioCtx = new (window.AudioContext || window.webkitAudioContext)();

  beepInterval = setInterval(() => {

    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();

    osc.type = "square";
    osc.frequency.value = 1000;

    gain.gain.value = 0.2;

    osc.connect(gain);
    gain.connect(audioCtx.destination);

    osc.start();

    setTimeout(() => osc.stop(), 200);

  }, 400);
}

// =========================
// 사이렌 종료
// =========================
function stopBeep(){

  clearInterval(beepInterval);
  beepInterval = null;

  if(audioCtx){
    audioCtx.close();
    audioCtx = null;
  }
}

// =======================================================
// 🔥 공통 처리 함수 (핵심)
// =======================================================
function handleRequest(data){

  if(!data.requestID) return;
  if(handled.has(data.requestID)) return;
  if(current === data.requestID) return;

  current = data.requestID;
  confirmed = true;

  setButtons(true);

  // ✅ UI 카드 표시
  document.getElementById("card").classList.remove("hidden");
  document.getElementById("standby").style.display = "none";

  document.getElementById("reqid").innerText = data.requestID;
  document.getElementById("summary").innerText = data.summary || "-";
  document.getElementById("eta").innerText = data.eta || "-";

  document.getElementById("status").innerText = "WAITING RESPONSE";

  notify(data.requestID, data.summary);
  startBeep();
}
// =======================================================
// 🚨 WebSocket
// =======================================================
socket.on("new_request", (data) => {

  if(data.hospital !== HOSPITAL) return;

  handleRequest(data);
});

// =======================================================
// 🚨 polling (15초 백업)
// =======================================================
setInterval(async () => {

  try {

    const res = await fetch(SERVER + "/latest/" + HOSPITAL);
    const data = await res.json();

    if (!data || !data.requestID) return;  // ⭐ 추가

    handleRequest(data);

  } catch(e){
    console.log("poll error:", e);
  }

}, 15000);

// =======================================================
// 📩 응답
// =======================================================
async function send(r){

  if(!current || !confirmed){
    alert("먼저 요청 확인");
    return;
  }

  const res = await fetch(
    `${SERVER}/response?requestID=${current}&hospital=${HOSPITAL}&response=${r}`
  );

  const text = await res.text();

  if(text === "already responded"){
    alert("이미 처리됨");
    return;
  }

  handled.add(current);

  stopBeep();

  // =========================
  // ✅ 여기 넣는 위치 (핵심)
  // =========================
  document.getElementById("status").innerText =
    "RESPONDED (" + r + ")";

  document.getElementById("card").style.boxShadow =
    r === "가능"
    ? "0 0 20px rgba(0,255,0,0.7)"
    : "0 0 20px rgba(255,0,0,0.7)";

  setButtons(false);

  document.getElementById("card").classList.add("hidden");
  document.getElementById("standby").style.display = "block";

  setTimeout(()=>{
    document.getElementById("status").innerText = "WAITING";
  },1500);

  current = null;
  confirmed = false;
}

</script>

</body>
</html>
